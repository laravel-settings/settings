{
  "name": "laravel-settings/settings",
  "description": "Simple settings management package for Laravel",
  "keywords": [
      "laravel",
      "laravel-settings",
      "settings",
      "configuration",
      "driver",
      "json",
      "json-settings"
  ],
  "type": "library",
  "homepage": "https://github.com/laravel-settings/settings",
  "license": "MIT",
  "authors": [
      {
          "name": "Ali Hassan",
          "email": "ali.dev.uk@gmail.com",
          "role": "Senior Developer"
      },
      {
          "name": "Sam Hasan",
          "email": "sam@barameg.co",
          "role": "Solution Architect"
      }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "*"
  },

  "require-dev": {
    "orchestra/testbench": "^10.9",
    "pestphp/pest": "^4.3",
    "pestphp/pest-plugin-laravel": "^4.0"
  },

  "autoload": {
    "psr-4": {
      "LaravelSettings\\Settings\\": "app/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "LaravelSettings\\Settings\\Tests\\": "tests/"
    }
  },

  "extra": {
    "laravel": {
      "providers": [
        "LaravelSettings\\Settings\\Providers\\SettingsServiceProvider"
      ]
    }
  },

  "minimum-stability": "stable",
  "prefer-stable": true,

  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
